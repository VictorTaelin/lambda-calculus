#!/usr/bin/env sh
set -e

src=$0
while [ -L "$src" ]; do
  dir=$(CDPATH= cd -P -- "$(dirname -- "$src")" && pwd)
  link=$(readlink "$src")
  case $link in
    /*) src=$link ;;
    *) src=$dir/$link ;;
  esac
done
dir=$(CDPATH= cd -P -- "$(dirname -- "$src")" && pwd)

exec bun "$dir/../src/cli.ts" "$@"
