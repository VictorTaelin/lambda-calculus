#!/usr/bin/env sh
set -e

src=$0
while [ -L "$src" ]; do
  dir=$(CDPATH= cd -P -- "$(dirname -- "$src")" && pwd)
  link=$(readlink "$src")
  case $link in
    /*) src=$link ;;
    *) src=$dir/$link ;;
  esac
done
dir=$(CDPATH= cd -P -- "$(dirname -- "$src")" && pwd)

if [ -x "$dir/lam-hs-bin" ]; then
  exec "$dir/lam-hs-bin" "$@"
fi

exec "$dir/lam-ts" "$@"
