#!/usr/bin/env sh
set -e

src=$0
while [ -L "$src" ]; do
  dir=$(CDPATH= cd -P -- "$(dirname -- "$src")" && pwd)
  link=$(readlink "$src")
  case $link in
    /*) src=$link ;;
    *) src=$dir/$link ;;
  esac
done
dir=$(CDPATH= cd -P -- "$(dirname -- "$src")" && pwd)

if [ -x "$dir/lam-hs-bin" ]; then
  exec "$dir/lam-hs-bin" "$@"
fi

printf '%s\n' "lam-hs: Haskell backend is not installed." >&2
printf '%s\n' "Install ghc and reinstall lambda-calculus, or use lam-ts." >&2
exit 127
